---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(d: Date) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
}
---

<BaseLayout title="Blog — Burdweiser.com" description="All posts on VMware, Kubernetes, NVIDIA, AI infrastructure and homelab engineering.">
  <div class="container page-wrap">
    <div class="page-header">
      <div class="page-eyebrow">all posts</div>
      <h1>Blog</h1>
    </div>

    {posts.length === 0 ? (
      <div class="empty">No posts yet — check back soon.</div>
    ) : (
      <div class="post-list">
        {posts.map(post => (
          <article class="post-item">
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()} class="post-date">
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.tags?.slice(0,2).map((tag: string) => (
                <span class={`pill ${tag.toLowerCase().replace(/[^a-z]/g,'').slice(0,6)}`}>{tag}</span>
              ))}
            </div>
            <h2 class="post-title">
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h2>
            {post.data.description && (
              <p class="post-excerpt">{post.data.description}</p>
            )}
            <a href={`/blog/${post.slug}/`} class="post-read">Read more →</a>
          </article>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .page-wrap { padding-top: 0; }
  .page-header {
    padding: 48px 0 0;
    margin-bottom: 0;
  }
  .page-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }
  h1 {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 500;
    letter-spacing: -0.5px;
    margin-bottom: 32px;
  }
  .empty { padding: 48px 0; color: var(--text2); font-size: 14px; }
  .post-list { border-top: 0.5px solid var(--border); }
  .post-item {
    padding: 24px 0;
    border-bottom: 0.5px solid var(--border);
    transition: background 0.15s;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
  }
  .post-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text3);
  }
  .post-title {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: -0.2px;
    margin-bottom: 8px;
    line-height: 1.4;
  }
  .post-title a { color: var(--text); text-decoration: none; transition: color 0.15s; }
  .post-title a:hover { color: var(--accent); text-decoration: none; }
  .post-excerpt { font-size: 13px; color: var(--text2); line-height: 1.6; margin-bottom: 10px; max-width: 680px; }
  .post-read {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
  }
  .post-read:hover { text-decoration: underline; }
</style>
